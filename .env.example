# GEMINI_API_KEY: usada pelo endpoint /api/chef-sommelier.
# Crie uma chave no Google AI Studio e coloque o valor real em um arquivo .env local.
GEMINI_API_KEY="sua_chave_gemini_aqui"

# APP_URL: URL base da aplicacao em producao. Em desenvolvimento pode ficar assim.
APP_URL="http://localhost:3000"
